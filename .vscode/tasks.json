{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sync to Pi",
            "type": "shell",
            "command": "bash",
            "args": [".vscode/sync.sh"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Build ggk library",
            "type": "shell",
            "command": "bash",
            "args": [
                ".vscode/build.sh",
                "${workspaceFolder}"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        }
    ]
}
