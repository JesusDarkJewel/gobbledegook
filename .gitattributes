# Автоматически определять текстовые файлы и нормализовать их до LF при коммите
* text=auto eol=lf

# Явно указать для часто используемых типов файлов
*.c     text eol=lf
*.cpp   text eol=lf
*.h     text eol=lf
*.hpp   text eol=lf
*.sh    text eol=lf
*.py    text eol=lf
*.am    text eol=lf
*.ac    text eol=lf
*.in    text eol=lf
*.m4    text eol=lf
Makefile.am text eol=lf
configure.ac text eol=lf
*.txt   text eol=lf

# Файлы, которые являются бинарными (не должны изменяться)
*.a     binary
*.o     binary
*.so    binary
*.dll   binary
*.exe   binary
*.png   binary
*.jpg   binary
*.ico   binary